rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function getRoleFromClaims() {
      return request.auth.token.role is string ? request.auth.token.role : null;
    }

    function getRoleFromUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role is string
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function getRole() {
      return getRoleFromClaims() != null
        ? getRoleFromClaims()
        : getRoleFromUserDoc();
    }

    function isSuperAdmin() {
      return getRole() == 'super_admin';
    }

    function isAdmin() {
      return getRole() == 'admin';
    }

    function isLeader() {
      return getRole() == 'leader';
    }

    function getUserStageFromClaims() {
      return request.auth.token.stageId is string ? request.auth.token.stageId : null;
    }

    function getUserStageFromUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.stageId is string
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.stageId
        : null;
    }

    function getUserStage() {
      return getUserStageFromClaims() != null
        ? getUserStageFromClaims()
        : getUserStageFromUserDoc();
    }

    function isSameStage(stageId) {
      return stageId is string &&
        getUserStage() is string &&
        stageId == getUserStage();
    }

    function teamExists(teamId) {
      return exists(/databases/$(database)/documents/teams/$(teamId));
    }

    function getTeamStage(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId)).data.stageId;
    }

    function canCreateStageScoreForTeam(teamId, stageId) {
      return teamExists(teamId) &&
        isSameStage(stageId) &&
        isSameStage(getTeamStage(teamId));
    }

    function getScoreTargetType() {
      return request.resource.data.targetType == null ? 'team' : request.resource.data.targetType;
    }

    function isValidScorePayload() {
      return (getScoreTargetType() == 'team' || getScoreTargetType() == 'member') &&
        request.resource.data.applyToTeamTotal == true &&
        (
          getScoreTargetType() == 'team' ||
          (request.resource.data.memberKey is string &&
            request.resource.data.memberName is string)
        );
    }

    function userDocInMyStage(userData) {
      return (userData.stageId is string && isSameStage(userData.stageId)) ||
        (userData.teamId is string && teamExists(userData.teamId) && isSameStage(getTeamStage(userData.teamId)));
    }

    function leaderOnlyUpdatesTeamPoints() {
      // Kept for backward compatibility if needed, but not actively restricting teams anymore.
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['totalPoints']) &&
        request.resource.data.totalPoints is number &&
        isSameStage(resource.data.stageId) &&
        isSameStage(request.resource.data.stageId);
    }

    function isValidAuditOperation(operation) {
      return operation == 'create' || operation == 'delete';
    }

    function isValidAuditEntityType(entityType) {
      return entityType == 'team' || entityType == 'task' || entityType == 'member';
    }

    function hasValidStageForAuditCreate() {
      return isSuperAdmin() ||
        ((isAdmin() || isLeader()) &&
          request.resource.data.stageId is string &&
          isSameStage(request.resource.data.stageId));
    }

    function isValidAuditLogCreate() {
      return request.resource.data.kind == 'audit' &&
        isValidAuditOperation(request.resource.data.operation) &&
        isValidAuditEntityType(request.resource.data.entityType) &&
        request.resource.data.entityId is string &&
        request.resource.data.entityName is string &&
        request.resource.data.actorId == request.auth.uid &&
        hasValidStageForAuditCreate();
    }

    // Users: any authenticated user can create their own doc (for account setup)
    // super_admin has full access. admin can read users in same stage? The prompt says "admin can only read/write documents where stageId == ...". But users might not have stageId in db or it's on their token. Let's let them read all for UI to work or read same stage.
    match /users/{userId} {
      allow read: if isSuperAdmin() ||
        request.auth.uid == userId ||
        ((isAdmin() || isLeader()) && userDocInMyStage(resource.data));
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if isSuperAdmin() || request.auth.uid == userId || (isAdmin() && isSameStage(resource.data.stageId) && isSameStage(request.resource.data.stageId));
    }

    match /teams/{teamId} {
      allow read: if true;
      allow create: if isSuperAdmin() ||
        ((isAdmin() || isLeader()) &&
          request.resource.data.stageId is string &&
          isSameStage(request.resource.data.stageId));
      allow update: if isSuperAdmin() || 
                    ((isAdmin() || isLeader()) && isSameStage(resource.data.stageId) && isSameStage(request.resource.data.stageId));
      allow delete: if isSuperAdmin() || ((isAdmin() || isLeader()) && isSameStage(resource.data.stageId));
    }

    match /tasks/{taskId} {
      allow read: if true;
      allow create: if (isSuperAdmin() || isAdmin() || isLeader()) &&
        request.resource.data.createdBy == request.auth.uid &&
        (isSuperAdmin() || (request.resource.data.stageId is string && isSameStage(request.resource.data.stageId)) || request.resource.data.stageId == null);
      allow update: if isSuperAdmin() ||
        (
          resource.data.createdBy == request.auth.uid &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['status']) &&
          request.resource.data.status == 'archived'
        );
      allow delete: if isSuperAdmin();
    }

    match /scores/{scoreId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || ((isAdmin() || isLeader()) && isSameStage(resource.data.stageId)));
      allow create: if isAuthenticated() && (
        isSuperAdmin() ||
        ((isAdmin() || isLeader()) &&
          canCreateStageScoreForTeam(request.resource.data.teamId, request.resource.data.stageId) &&
          isValidScorePayload())
      );
      allow update, delete: if isAuthenticated() && (isSuperAdmin() || (isAdmin() && isSameStage(resource.data.stageId)));
    }

    match /member_stats/{memberKey} {
      allow read: if isAuthenticated() && (isSuperAdmin() || ((isAdmin() || isLeader()) && isSameStage(resource.data.stageId)));
      allow create: if isAuthenticated() && (isSuperAdmin() || ((isAdmin() || isLeader()) && isSameStage(request.resource.data.stageId)));
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        ((isAdmin() || isLeader()) &&
          isSameStage(resource.data.stageId) &&
          isSameStage(request.resource.data.stageId))
      );
      allow delete: if isAuthenticated() && (isSuperAdmin() || (isAdmin() && isSameStage(resource.data.stageId)));
    }

    match /logs/{logId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        ((isAdmin() || isLeader()) && isSameStage(resource.data.stageId))
      );
      allow create: if isAuthenticated() && isValidAuditLogCreate();
      allow update, delete: if isSuperAdmin();
    }
  }
}
